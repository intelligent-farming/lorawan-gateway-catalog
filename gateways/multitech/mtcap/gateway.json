  "model": "mtcap",
  "name": "MultiTech Conduit AP (MTCAP)",
  "regions": [
    "EU868",
    "US915"
  ],
  "chipset": "SX1308",
  "oui": [
    "000800",
    "008000"
  ],
  "admin": {
    "defaultUrl": "https://192.168.2.1",
    "defaultCredentials": null,
    "credentialsNote": "mPower (AEP) has no factory login — first boot runs commissioning, where you create the admin username and password. Reach the UI at https://192.168.2.1 over the Ethernet LAN port. The packet-forwarder screen is a JSON editor (Manual Configuration), so the full config above pastes in directly."
  },
  "configMethods": [
    "web-ui",
    "forwarder-file"
  ],
  "packetForwarders": [
    "semtech-udp",
    "basics-station"
  ],
  "config": {
    "semtech-udp": {
      "template": "config/semtech-udp.tmpl.json",
      "forwarderFilePath": "/var/config/lora/global_conf.json"
    },
    "basics-station": {
      "template": "config/basics-station.tmpl.conf"
    },
    "web-ui": {
      "path": "LoRaWAN → Network Settings → LoRa Mode: Packet Forwarder → Manual Configuration"
    }
  },
