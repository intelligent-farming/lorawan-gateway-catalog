{
  "name": "@intelligent-farming/lorawan-gateway-catalog",
  "version": "0.1.3",
  "description": "Curated LoRaWAN gateway profiles to assist an operator in connecting a gateway to ChirpStack.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intelligent-farming/lorawan-gateway-catalog.git"
  },
  "homepage": "https://github.com/intelligent-farming/lorawan-gateway-catalog#readme",
  "bugs": {
    "url": "https://github.com/intelligent-farming/lorawan-gateway-catalog/issues"
  },
  "files": ["dist/", "definitions/", "gateways/", "!gateways/**/reference"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "scaffold": "node scripts/scaffold-gateway.js",
    "validate": "node scripts/validate-fixtures.js",
    "validate:check": "node scripts/validate-fixtures.js --check",
    "test": "npm run build && node --test --test-reporter=spec test/smoke.js test/conformance.js",
    "docs": "typedoc && mv docs/README.md docs/api-doc.md"
  },
  "dependencies": {
    "@intelligent-farming/oui-registry": "^0.1.2",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
